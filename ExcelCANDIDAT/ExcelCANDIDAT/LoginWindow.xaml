<Window x:Class="ExcelCANDIDAT.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="300"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Border Padding="24" Background="#F4F6F8">
        <StackPanel>
            <TextBlock Text="Учет кандидатов"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Вход для пользователя системы"
                       Foreground="#4B5563"
                       Margin="0,0,0,22"/>

            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginTextBox"
                     Height="32"
                     Margin="0,4,0,12"/>

            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="32"
                         Margin="0,4,0,16"
                         KeyDown="PasswordBox_KeyDown"/>

            <TextBlock Text="Тестовые пользователи: hr / hr123, admin / admin123"
                       Foreground="#6B7280"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>

            <Button Content="Войти"
                    Height="34"
                    Width="110"
                    HorizontalAlignment="Right"
                    Click="LoginButton_Click"/>
        </StackPanel>
    </Border>
</Window>
